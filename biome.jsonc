{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "formatter": {
    "indentStyle": "space", // default is `tab`
    "indentWidth": 2,
    "lineWidth": 100 // default is `80`
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": ["app/**/*.{js,jsx,ts,tsx,json}"]
  }
}
